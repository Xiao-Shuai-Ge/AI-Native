# AI Native environment configuration (copy to .env and fill in secrets)
# All secrets must come from environment variables; never commit real keys.

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Redis (Compose service: redis) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- PostgreSQL (Compose service: postgres) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=ainative
POSTGRES_PASSWORD=ainative
POSTGRES_DB=ainative

# --- Dapr (sidecar, enabled from Day 3) ---
DAPR_HTTP_PORT=3500
DAPR_GRPC_PORT=50001

# --- MCP Server (enabled from Day 7) ---
MCP_SERVER_URL=http://localhost:8001

# --- Observability (Compose services: jaeger, prometheus) ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
JAEGER_UI_URL=http://localhost:16686
PROMETHEUS_URL=http://localhost:9090

# --- LLM providers (Day 2+) ---
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen3:8b
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=1
